# ===== Agamotto · environment template =====
# Copy to .env.local (gitignored) and fill in.

# ── Backend ──
# Dev (SQLite, default if empty):
AGAMOTTO_DATABASE_URL=

# Prod (Supabase Postgres — use the "Connection pooling" URI from Supabase dashboard):
# Format: postgresql+psycopg://postgres.<ref>:<password>@<pooler-host>:6543/postgres
# AGAMOTTO_DATABASE_URL=postgresql+psycopg://postgres.nciwpsmupophvkzexjdt:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

AGAMOTTO_API_HOST=0.0.0.0
AGAMOTTO_API_PORT=8000
AGAMOTTO_API_CORS_ORIGINS=["http://localhost:3000","https://agamotto.vercel.app"]
AGAMOTTO_SIMULATION_DEFAULT_RUNS=100000
AGAMOTTO_SIMULATION_SEED=42
AGAMOTTO_MODEL_SET_VERSION=agamotto_ensemble_0.1.0

# Optional providers (leave empty for free tier)
AGAMOTTO_STATORIUM_API_KEY=
AGAMOTTO_API_FOOTBALL_KEY=
AGAMOTTO_OPEN_METEO_BASE=https://api.open-meteo.com/v1

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://nciwpsmupophvkzexjdt.supabase.co
# Publishable / anon key — safe in client bundle:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase admin (server-only, NEVER expose in client) ──
SUPABASE_SERVICE_ROLE_KEY=
